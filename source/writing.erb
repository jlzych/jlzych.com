<!DOCTYPE html>
<html>
  <%= partial "head_tag" %>

  <body class="writing">
    <header class="writing__header u-full-width">
      <h1 class="writing__headline">
        <span class="writing__headline--intro">

          <span class="arrow arrow--left"><%= partial "arrow" %></span>
          <span class="arrow arrow--right"><%= partial "arrow" %></span>

          Principles of
        </span>

        Writing Well
      </h1>
    </header>

    <div id="main" role="main">

      <article class="content writing__content">
        <%= partial "writing_principles" %>

        <hr>

        <em><%= "Last updated on #{current_page.data.last_updated_date}" %></em>
      </article>

      <%= partial "footer_tag" %>

    </div>

    <%= partial "noise" %>

  <!-- Custom page scripts -->
  <script>
    if (document.querySelector) {
      // Rotate the hue of the header based on the day of the year
      var today = new Date();
      var hueValue = today.getDate() + today.getMonth() * 30.4;
      var hueString = "hue-rotate(" + hueValue + "deg)";

      var header = document.querySelector(".writing__header");
      header.style.webkitFilter = hueString;
      header.style.filter = hueString;

      // Add anchor links to the headlines
      var headlines = document.querySelector(".writing__content").querySelectorAll("h1, h2, h3, h4, h5, h6");
      var link, headline;
      var i = 0;

      for (i; i < headlines.length; i++) {
        headline = headlines[i];

        // Only do this shiz if this function exists
        if (headline.insertAdjacentHTML) {
          link = document.createElement("a");
          link.text = "#";
          link.href = "#" + headline.id;
          link.classList.add("headline-anchor-link");

          headline.insertAdjacentHTML(
            "beforeend",
            "<a href='#" + headline.id + "' class='headline-anchor-link'>#</a>"
          );
        }
      }
    }
  </script>
  </body>
</html>
